{
  "skill_name": "recap-commit",
  "evals": [
    {
      "id": 1,
      "name": "simple-single-session",
      "prompt": "지난 커밋 이후에 Claude 도움 받아서 로그인 버그 수정했는데, 그 과정을 커밋에 기록하고 싶어. /recap-commit 해줘.",
      "expected_output": "git commit이 생성되고, body에 <details> 블록으로 AI Recap이 포함됨. Key Prompts에 원문이 보존되어 있어야 함. Assessment 섹션에 goal/outcome/helpfulness 필드가 있어야 함.",
      "assertions": [
        {
          "name": "commit_created",
          "type": "output_contains",
          "expected": "git commit",
          "description": "git commit 명령이 실행되었는지"
        },
        {
          "name": "has_details_block",
          "type": "output_contains",
          "expected": "<details>",
          "description": "커밋 메시지에 <details> 블록이 포함되었는지"
        },
        {
          "name": "has_key_prompts",
          "type": "output_contains",
          "expected": "Key Prompts",
          "description": "Key Prompts 섹션이 있는지"
        },
        {
          "name": "has_assessment",
          "type": "output_contains",
          "expected": "Assessment",
          "description": "Assessment(Facet) 섹션이 있는지"
        },
        {
          "name": "has_verbatim_quote",
          "type": "output_contains",
          "expected": "> ",
          "description": "원문 인용(blockquote)이 포함되어 있는지"
        }
      ],
      "files": []
    },
    {
      "id": 2,
      "name": "no-sessions-since-commit",
      "prompt": "방금 커밋했는데 바로 /recap-commit 해줘",
      "expected_output": "세션이 없다는 안내 메시지와 함께 /commit 사용을 권유",
      "assertions": [
        {
          "name": "graceful_empty_handling",
          "type": "output_contains_any",
          "expected": ["No", "없", "찾을 수 없", "/commit"],
          "description": "세션 없을 때 graceful하게 처리하는지"
        }
      ],
      "files": []
    },
    {
      "id": 3,
      "name": "multi-session-complex",
      "prompt": "오늘 오전부터 3시간 동안 Claude랑 인증 시스템 리팩토링을 했어. 세션을 여러 번 나눠서 진행했는데, 처음에는 JWT에서 세션 기반으로 바꾸려다가 중간에 방향을 바꿔서 OAuth2 PKCE로 갔거든. 그 과정의 key prompts랑 시행착오를 포함해서 /recap-commit 해줘.",
      "expected_output": "여러 세션을 통합한 recap. 방향 전환(JWT→OAuth2 PKCE) 관련 프롬프트가 key prompt로 선택되어야 함. friction에 wrong_approach가 포함되어야 함.",
      "assertions": [
        {
          "name": "multi_session_handling",
          "type": "output_contains_any",
          "expected": ["session", "세션"],
          "description": "여러 세션을 인식하고 처리했는지"
        },
        {
          "name": "direction_change_captured",
          "type": "output_contains_any",
          "expected": ["direction", "방향", "changed", "전환", "OAuth", "PKCE"],
          "description": "방향 전환이 key prompt나 summary에 반영되었는지"
        },
        {
          "name": "commit_format_correct",
          "type": "output_contains",
          "expected": "<details>",
          "description": "올바른 커밋 포맷으로 생성되었는지"
        }
      ],
      "files": []
    }
  ]
}
